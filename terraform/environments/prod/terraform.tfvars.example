project_name = "taskflow"
environment  = "prod"
aws_region   = "ap-south-1"
dr_region    = "ap-southeast-1"
vpc_cidr     = "10.30.0.0/16"

# One NAT Gateway per AZ for production availability.
single_nat_gateway = false

certificate_arn = "" # Terraform creates and validates ACM when this is blank.
hosted_zone_id  = "REPLACE_ME"
domain_name     = "taskflow.example.com"

enable_global_accelerator  = true
enable_deletion_protection = true

web_instance_type    = "t3.small"
app_instance_type    = "t3.small"
web_min_size         = 2
web_desired_capacity = 2
web_max_size         = 6
app_min_size         = 2
app_desired_capacity = 2
app_max_size         = 6

database_instance_class        = "db.t4g.small"
database_allocated_storage     = 50
database_max_allocated_storage = 500
database_multi_az              = true
database_deletion_protection   = true
database_skip_final_snapshot   = false
database_backup_retention_days = 14
database_performance_insights  = true
database_apply_immediately     = false
dr_backup_retention_days       = 90

artifact_bucket_force_destroy = false
alarm_email                  = "platform-alerts@example.com"

default_tags = {
  Owner       = "platform-team"
  CostCenter  = "production"
  DataClass   = "internal"
}
